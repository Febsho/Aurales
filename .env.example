VITE_TMDB_API_KEY=your_tmdb_api_key_here
VITE_TVDB_API_KEY=your_tvdb_api_key_here
VITE_TRAKT_CLIENT_ID=your_trakt_client_id_here
VITE_TRAKT_CLIENT_SECRET=your_trakt_client_secret_here

# Simkl OAuth credentials
# VITE_ prefix = bundled in JS (safe for public client ID)
# No VITE_ prefix = compiled into Rust binary only (secret stays off the JS bundle)
VITE_SIMKL_CLIENT_ID=
SIMKL_CLIENT_SECRET=
VITE_SIMKL_REDIRECT_URI=http://localhost:42814/auth/simkl/callback
