{
  "$schema": "../node_modules/@tauri-apps/cli/config.schema.json",
  "productName": "Orynt",
  "version": "0.1.0",
  "identifier": "com.orynt.app",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:5173",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "Orynt",
        "width": 1280,
        "height": 800,
        "minWidth": 900,
        "minHeight": 600,
        "resizable": true,
        "fullscreen": false,
        "decorations": true,
        "transparent": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' https://image.tmdb.org https://artworks.thetvdb.com https://*.tmdb.org data:; connect-src 'self' https://api.themoviedb.org https://api4.thetvdb.com https://api.trakt.tv https://*; style-src 'self' 'unsafe-inline'"
    }
  },
  "bundle": {
    "active": true,
    "targets": ["msi", "nsis"],
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "windows": {
      "nsis": {
        "installMode": "both",
        "displayLanguageSelector": false
      },
      "wix": {
        "language": "en-US"
      }
    },
    "shortDescription": "A modern streaming catalog app",
    "longDescription": "Orynt is a modern desktop streaming catalog app with TMDB/TVDB metadata, Trakt sync, Stremio addon support, and mpv playback."
  }
}
